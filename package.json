{
  "name": "portfolio-v2",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "homepage": "https://sheikhsarvar.github.io/portfolio/",
  "scripts": {
    "dev": "vite --base=/portfolio/",
    "prebuild": "node scripts/generate-seo-assets.mjs",
    "build": "tsc && vite build --base=/portfolio/ && node scripts/run-react-snap.mjs",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.0",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.13",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "gh-pages": "^6.1.1",
    "postcss": "^8.4.39",
    "puppeteer": "^25.3.0",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "reactSnap": {
    "source": "dist",
    "include": [
      "/"
    ],
    "crawl": false,
    "skipThirdPartyRequests": true,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ]
  }
}
